FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY voice_proxy.py ./
RUN pip install --no-cache-dir fastapi uvicorn httpx python-multipart pydub

ENV VOICE_PROXY_PORT=8001
EXPOSE 8001
CMD ["python", "voice_proxy.py"]
